APP__ENV=dev
APP__LOG_LEVEL=INFO

DB__HOST=localhost
DB__PORT=5432
DB__NAME=krisha_agent
DB__USER=krisha
DB__PASSWORD=change_me

REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=change_me_to_a_long_random_password

TELEGRAM__BOT_TOKEN=change_me
# Access control: comma/semicolon-separated Telegram user ids allowed to use the
# bot. EMPTY MEANS OPEN TO EVERYONE — any stranger can trigger searches and burn
# paid DeepSeek/2GIS quota. Set it before exposing a production bot.
TELEGRAM__ALLOWED_USER_IDS=
# Per-user sliding-window rate limit (messages+callbacks per minute).
TELEGRAM__RATE_LIMIT_PER_MINUTE=20

API__TWO_GIS_API_KEY=change_me
API__DEEPSEEK_API_KEY=change_me
# Optional observability integrations (blank disables them)
API__LANGSMITH_API_KEY=
API__LANGSMITH_PROJECT=
API__SENTRY_DSN=

PARSER__MIN_DELAY_SECONDS=1.0
PARSER__MAX_DELAY_SECONDS=3.0
PARSER__TIMEOUT_MS=30000
PARSER__DEDUP_TTL_SECONDS=86400
PARSER__MAX_RESULTS=6

SCORING__MODEL=deepseek-chat
SCORING__TEMPERATURE=0.2
SCORING__TIMEOUT_SECONDS=15.0

SCHEDULER__POLL_INTERVAL_SECONDS=60
SCHEDULER__BATCH_SIZE=50
SCHEDULER__RUNTIME=inline
# Parser canary: periodically parses a reference krisha search page and alerts
# the admin chat when extraction breaks (markup change / anti-bot block).
SCHEDULER__CANARY_ENABLED=false
SCHEDULER__CANARY_ADMIN_CHAT_ID=
SCHEDULER__CANARY_CITY=Almaty
SCHEDULER__CANARY_INTERVAL_HOURS=6

ARQ__QUEUE_NAME=krisha:monitor
ARQ__JOB_TIMEOUT_SECONDS=900
ARQ__MAX_TRIES=3

NOTION__ENABLED=false
NOTION__API_TOKEN=
NOTION__DATABASE_ID=
NOTION__TIMEOUT_SECONDS=15.0

# Optional override for Alembic
# DATABASE_URL=postgresql+asyncpg://krisha:change_me@localhost:5432/krisha_agent
